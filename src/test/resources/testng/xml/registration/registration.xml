<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Registration test suite" verbose="1">
    <test name="smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="tests.registration.RegistrationTests"></class>
        </classes>
    </test>

    <test name="critical-path">
        <groups>
            <run>
                <include name="critical-path"/>
            </run>
        </groups>

        <classes>
            <class name="tests.registration.RegistrationTests"></class>
        </classes>
    </test>

    <test name="regression">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="tests.registration.RegistrationTests"></class>
        </classes>
    </test>
</suite>

